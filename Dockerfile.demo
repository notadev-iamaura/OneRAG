# OneRAG 라이브 데모 Dockerfile (경량 버전)
#
# 핵심 전략: 선택적 COPY + 빈 __init__.py로 전이적 import 차단
# - torch/sentence-transformers 의존성 제거 (~2GB 절약)
# - 전체 60+ 패키지 대신 데모 전용 17개 패키지만 설치
#
# 예상 이미지 크기: ~300MB (기존 2.5GB 대비 88% 절감)
# 메모리 예산: ~315MB (Railway Hobby 512MB)
#
# 빌드: docker build -f Dockerfile.demo -t onerag-demo .
# 실행: docker run -p 8000:8000 -e GOOGLE_API_KEY=your-key onerag-demo

FROM python:3.11-slim

WORKDIR /app

# 시스템 의존성 (최소 + libmagic for MIME 타입 검증)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential libmagic1 && rm -rf /var/lib/apt/lists/*

# uv 설치 (빠른 패키지 관리)
COPY --from=ghcr.io/astral-sh/uv:0.6 /uv /usr/local/bin/uv

# 데모 전용 패키지만 설치 (전체 60+ 대신 17개)
# uv sync 대신 명시적 패키지 목록으로 torch/sentence-transformers 방지
RUN uv pip install --system --no-cache \
    "fastapi>=0.104.0,<1" "uvicorn[standard]>=0.24.0,<1" "python-multipart>=0.0.6" \
    "chromadb>=0.5.0" "google-generativeai>=0.6.0,<1" \
    "langchain-text-splitters>=0.0.1" "langchain-core>=0.1.0" \
    "slowapi>=0.1.9,<1" "pypdf>=5.0.0,<7" "python-docx>=1.1.0,<2" \
    "pydantic-settings>=2.1.0,<3" "python-dotenv>=1.0.0,<2" "python-magic>=0.4.27" \
    "structlog>=23.2.0,<25" "numpy>=1.26.0,<2" \
    "openai>=1.10.0,<2" "anthropic>=0.16.0,<1"

# ─── 필요한 소스만 선택적 복사 (22개 파일) ───
COPY app/__init__.py app/__init__.py
COPY app/lib/logger.py app/lib/logger.py
COPY app/lib/llm_client.py app/lib/llm_client.py
COPY app/lib/types.py app/lib/types.py
COPY app/lib/errors/ app/lib/errors/
COPY app/api/demo/ app/api/demo/
COPY app/modules/core/embedding/gemini_embedder.py app/modules/core/embedding/gemini_embedder.py
COPY app/modules/core/embedding/interfaces.py app/modules/core/embedding/interfaces.py
COPY easy_start/sample_data/ easy_start/sample_data/
COPY demo_main.py .

# ─── 빈 __init__.py로 전이적 import 차단 ───
# app/api/__init__.py: admin, chat, health, prompts, upload 프로덕션 모듈 로드 방지
# app/lib/__init__.py: config_loader, langsmith_client 체인 활성화 방지
# app/modules/*: local_embedder → sentence-transformers → torch (~2GB) 로드 방지
RUN touch app/api/__init__.py app/lib/__init__.py \
    app/modules/__init__.py app/modules/core/__init__.py \
    app/modules/core/embedding/__init__.py

# 보안: non-root 사용자
RUN adduser --disabled-password --gecos "" --no-create-home appuser && \
    chown -R appuser:appuser /app
USER appuser

# 환경 변수 기본값
ENV PORT=8000 \
    PYTHONPATH=/app \
    PYTHONUNBUFFERED=1 \
    DEMO_MAX_SESSIONS=50 \
    DEMO_TTL_SECONDS=600 \
    DEMO_MAX_FILE_SIZE_MB=10 \
    DEMO_MAX_DOCS_PER_SESSION=5 \
    DEMO_DAILY_API_LIMIT=500 \
    DEMO_SAMPLE_LANGUAGE=ko

# 헬스 체크
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:${PORT}/health')" || exit 1

EXPOSE ${PORT}
CMD ["sh", "-c", "python -m uvicorn demo_main:app --host 0.0.0.0 --port ${PORT}"]
