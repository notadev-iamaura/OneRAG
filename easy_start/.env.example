# OneRAG Easy Start local environment template
#
# Copy this file to `.env` manually, or run:
#   uv run python easy_start/run.py
#
# LLM answer generation is optional. If no key is set, Easy Start still runs
# retrieval-only search.

# Google AI Studio (recommended free option)
GOOGLE_API_KEY=

# OpenRouter fallback option
OPENROUTER_API_KEY=

# Optional local Ollama fallback
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Optional UI/sample language: ko, en, ja, zh
EASY_START_LANG=ko
