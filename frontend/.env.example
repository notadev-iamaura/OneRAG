# ========================================
# 환경변수 설정 예시
# ========================================
# 이 파일을 복사하여 .env 파일을 생성하고
# 실제 값으로 수정하여 사용하세요.
# ========================================

# Railway 배포용 API URL
# Railway 대시보드 → 백엔드 서비스 → Settings → Domains에서 확인
VITE_API_BASE_URL=https://your-backend-service.up.railway.app

# 개발 환경 백엔드 URL (로컬 개발용)
VITE_DEV_API_BASE_URL=http://localhost:8000
VITE_DEV_WS_BASE_URL=ws://localhost:8000

# 환경 설정
VITE_DEV_MODE=true

# 로깅 레벨 (debug, info, warn, error)
VITE_LOG_LEVEL=info

# 업로드 제한 설정
VITE_MAX_FILE_SIZE=52428800
VITE_MAX_FILES_PER_UPLOAD=10

# 채팅 설정
VITE_CHAT_TIMEOUT=30000
VITE_MAX_MESSAGE_LENGTH=2000

# 접근제어 설정
VITE_ACCESS_CODE=1127

# 기타 설정
VITE_APP_NAME="RAG 챗봇 시스템"
VITE_APP_VERSION="2.0.0"

# ===========================
# Feature Flags 설정
# ===========================
# true/false로 설정 가능
# 설정하지 않으면 서버 키가 필요 없는 챗봇만 기본 활성화됩니다.

# 챗봇 모듈
VITE_FEATURE_CHATBOT=true
VITE_FEATURE_CHATBOT_STREAMING=true
VITE_FEATURE_CHATBOT_HISTORY=true
VITE_FEATURE_CHATBOT_SESSION=true
VITE_FEATURE_CHATBOT_MARKDOWN=true

# 문서 관리 모듈
VITE_FEATURE_DOCUMENTS=false
VITE_FEATURE_DOCUMENTS_UPLOAD=false
VITE_FEATURE_DOCUMENTS_BULK_DELETE=false
VITE_FEATURE_DOCUMENTS_SEARCH=false
VITE_FEATURE_DOCUMENTS_PAGINATION=false
VITE_FEATURE_DOCUMENTS_DND=false
VITE_FEATURE_DOCUMENTS_PREVIEW=false

# 관리자 모듈
VITE_FEATURE_ADMIN=false
VITE_FEATURE_ADMIN_USERS=false
VITE_FEATURE_ADMIN_STATS=false
VITE_FEATURE_ADMIN_QDRANT=false
VITE_FEATURE_ADMIN_ACCESS=false

# 프롬프트 관리 모듈
VITE_FEATURE_PROMPTS=false
VITE_FEATURE_PROMPTS_TEMPLATES=false
VITE_FEATURE_PROMPTS_HISTORY=false

# 분석 모듈
VITE_FEATURE_ANALYSIS=false
VITE_FEATURE_ANALYSIS_REALTIME=false
VITE_FEATURE_ANALYSIS_EXPORT=false
VITE_FEATURE_ANALYSIS_VIZ=false

# ===========================
# 사용 예시
# ===========================
# 문서/관리자/프롬프트/분석 모듈은 보호 API를 호출하므로
# 서버 키를 브라우저에 노출하지 않는 별도 인증 경로가 있을 때만 활성화하세요.

# 1. 챗봇 전용 서비스
# VITE_FEATURE_CHATBOT=true
# VITE_FEATURE_DOCUMENTS=false
# VITE_FEATURE_ADMIN=false
# VITE_FEATURE_PROMPTS=false
# VITE_FEATURE_ANALYSIS=false

# 2. 문서 관리 전용 서비스
# VITE_FEATURE_CHATBOT=false
# VITE_FEATURE_DOCUMENTS=true
# VITE_FEATURE_ADMIN=true
# VITE_FEATURE_PROMPTS=true
# VITE_FEATURE_ANALYSIS=true

# 3. 최소 기능 (단순 챗봇)
# VITE_FEATURE_CHATBOT=true
# VITE_FEATURE_CHATBOT_STREAMING=false
# VITE_FEATURE_CHATBOT_HISTORY=false
# VITE_FEATURE_DOCUMENTS=false
# VITE_FEATURE_ADMIN=false
# VITE_FEATURE_PROMPTS=false
# VITE_FEATURE_ANALYSIS=false
