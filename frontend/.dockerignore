# Frontend Docker build context allowlist.
# Keep local env files, node_modules, test artifacts, and build outputs out of
# production image builds.

*

!package.json
!package-lock.json
!index.html
!vite.config.ts
!vitest.config.ts
!tsconfig.json
!tsconfig.app.json
!tsconfig.node.json
!eslint.config.js
!tailwind.config.cjs
!postcss.config.cjs
!components.json
!nginx.conf
!entrypoint.sh
!generate-config.js
!check-env.js
!Dockerfile
!.dockerignore
!.nvmrc

!public/
!public/**
!src/
!src/**
!scripts/
!scripts/**
!e2e/
!e2e/**
