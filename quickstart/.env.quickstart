# OneRAG quickstart environment template
#
# Copy this file to the repository root before running Docker quickstart:
#   cp quickstart/.env.quickstart .env
#
# Set GOOGLE_API_KEY for AI generation, sample loading, and query embeddings.
# Local embeddings remain available as an opt-in path with the local-embedding extra.

ENVIRONMENT=development

# LLM / generation
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash
GENERATION_PROVIDER=google
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# (선택) 리랭킹: 기본값은 LLM 리랭킹(approach=llm, provider=google)이며
# GOOGLE_API_KEY만으로 동작합니다. late-interaction(Jina ColBERT) 방식으로
# 전환하려면 app/config/features/reranking.yaml을 수정하고 아래 키를 설정하세요.
# JINA_API_KEY=

# Embeddings / vector database
EMBEDDINGS_PROVIDER=google
VECTOR_DB_PROVIDER=weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_GRPC_HOST=localhost
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=Documents

# Local admin API key. Replace before exposing the service outside localhost.
FASTAPI_AUTH_KEY=local-dev-only-change-me

# Optional fullstack frontend access gate
VITE_ACCESS_CODE=1127
